# SPA fallback — React Router handles routes like /login, /dashboard/create
# client-side, but they aren't real files/folders on the server. Without
# this rewrite, any hard navigation or page refresh on those URLs (or a
# window.location.href redirect, like the axios 401 handler uses) hits
# Apache directly, which 404s because no such file exists.
#
# This rule sends any request that isn't an existing file or directory
# back to index.html, so React Router can take over and render the
# right page client-side.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>
