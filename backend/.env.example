APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Google Sign-In — OAuth 2.0 Web Client ID (must match the frontend's
# VITE_GOOGLE_CLIENT_ID). Used to verify Google ID tokens at POST /api/auth/google.
GOOGLE_CLIENT_ID=898959091457-qj21kqfmqtglnmnisn7iob457193bs3j.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Visual / photo search (POST /api/search/image).
# Uses Hugging Face's free Inference API — create a free token at
# https://huggingface.co/settings/tokens (no billing/card required).
HUGGINGFACE_API_TOKEN=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
# Optional: override the image-classification model (default below).
HUGGINGFACE_VISION_MODEL=google/vit-base-patch16-224

# (Optional alternative engine) Google Cloud Vision API key — requires billing enabled.
GOOGLE_VISION_API_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ewaste23
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


# ── Mailpit (local dev/testing) — active mailer ──────────────
# Mailpit catches all outgoing mail; view it at http://localhost:8025
# No auth/encryption needed for Mailpit's default SMTP listener.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ewastemart.test"
MAIL_FROM_NAME="E-Waste Mart"

# ── Real Gmail SMTP — swap in when ready to go live ──────────
# Uncomment these and comment out the Mailpit block above to switch.
# MAIL_MAILER=smtp
# MAIL_SCHEME=smtps
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_USERNAME=lemalawry@gmail.com
# MAIL_PASSWORD=yefjhuwiqjllhpnz
